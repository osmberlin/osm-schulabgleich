{
  "name": "osm-schul-abgleich",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pipeline:download:jedeschule": "bun run scripts/pipeline-download-jedeschule.ts",
    "pipeline:download:osm": "bun run scripts/pipeline-download-osm.ts",
    "pipeline:download": "bun run scripts/pipeline-download.ts",
    "pipeline:match": "bun run scripts/pipeline-match.ts",
    "pipeline:match:force": "PIPELINE_FORCE_MATCH=1 bun run scripts/pipeline-match.ts",
    "pipeline:match:forcesplit-lands": "bun run scripts/pipeline-match-forcesplit-lands.ts",
    "pipeline:split-lands": "bun run scripts/pipeline-split-lands.ts",
    "pipeline:rebuild": "bun run scripts/pipeline-rebuild.ts",
    "pipeline": "bun run pipeline:download && bun run pipeline:match && bun run pipeline:split-lands",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "knip": "knip"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-router": "^1.157.16",
    "@turf/bbox": "^7.3.4",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/centroid": "^7.3.4",
    "@turf/circle": "^7.3.4",
    "@turf/difference": "^7.3.4",
    "@turf/distance": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "maplibre-gl": "^5.17.0",
    "nuqs": "^2.8.9",
    "osmtogeojson": "^3.0.0-beta.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@clack/prompts": "^1.2.0",
    "@maplibre/maplibre-gl-style-spec": "^24.7.0",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.3.11",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "knip": "^6.1.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.2"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run format"
  }
}
