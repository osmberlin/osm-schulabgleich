{
  "name": "osm-schul-abgleich",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "bun run check && rm -rf dist && vite build",
    "preview": "vite preview",
    "pipeline:download:jedeschule": "bun run scripts/pipeline-download-jedeschule.ts",
    "pipeline:download:osm": "bun run scripts/pipeline-download-osm.ts",
    "pipeline:download": "bun run scripts/pipeline-download.ts",
    "pipeline:ci:osm-meta-precheck": "bun run scripts/pipeline-ci-osm-meta-precheck.ts",
    "pipeline:ci:restore-osm-cache": "bun run scripts/pipeline-ci-restore-osm-cache.ts",
    "pipeline:ci:validate-source-meta": "bun run scripts/pipeline-ci-validate-source-meta.ts",
    "pipeline:ci:validate-rebuilt-snapshot": "bun run scripts/pipeline-ci-validate-rebuilt-snapshot.ts",
    "pipeline:match": "bun run scripts/pipeline-match.ts",
    "pipeline:match:force": "PIPELINE_FORCE_MATCH=1 bun run scripts/pipeline-match.ts",
    "pipeline:match:forcesplit-lands": "bun run scripts/pipeline-match-forcesplit-lands.ts",
    "pipeline:split-lands": "bun run scripts/pipeline-split-lands.ts",
    "pipeline:rebuild": "bun run scripts/pipeline-rebuild.ts",
    "pipeline": "bun run pipeline:download && bun run pipeline:rebuild",
    "stats:user-facing": "bun run scripts/report-user-facing-dataset-sizes.ts",
    "report:data-impact": "bun run scripts/report-data-impact.ts",
    "analysis:jedeschule": "bun run analysis/scripts/jedeschule-official-analysis.ts && bun run format",
    "analysis:identifier-csv": "bun run analysis/scripts/jedeschule-identifier-csv-analysis.ts && bun run format",
    "analysis:osm-school-tags": "bun run analysis/scripts/osm-school-tags-analysis.ts && bun run format",
    "analysis:matches-legal-provider": "bun run analysis/scripts/jedeschule-legal-provider-analysis.ts && bun run format",
    "changelog": "bun run changelog:verify && bun run changelog:build",
    "changelog:prefill": "changelog-kit-prefill",
    "changelog:verify": "changelog-kit-verify",
    "changelog:build": "changelog-kit-build",
    "update:deps": "bunx taze latest --include-locked --interactive --write",
    "update:gitdeps": "bun update @tordans/changelog-kit",
    "update:app": "bun install && bun run check && bun run changelog",
    "update": "bun run update:deps && bun run update:gitdeps && bun run update:app",
    "check": "bun run format && bun run lint && bun run typecheck",
    "lint": "oxlint -c oxlint.config.mjs .",
    "typecheck": "tsc -b",
    "format": "oxfmt -c oxfmt.config.mjs --write .",
    "format:check": "oxfmt -c oxfmt.config.mjs --check .",
    "test": "vitest run",
    "knip": "knip"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-router": "^1.168.25",
    "@tordans/changelog-kit": "github:tordans/changelog-kit#main",
    "@turf/bbox": "^7.3.5",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/centroid": "^7.3.5",
    "@turf/circle": "^7.3.5",
    "@turf/difference": "^7.3.5",
    "@turf/distance": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/simplify": "^7.3.5",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "itemsjs": "^2.4.4",
    "maplibre-gl": "^5.24.0",
    "osm-api": "^4.0.0",
    "osm2geojson-ultra": "^4.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-map-gl": "^8.1.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@clack/prompts": "^1.3.0",
    "@maplibre/maplibre-gl-style-spec": "^24.8.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.4",
    "@types/bun": "^1.3.13",
    "@types/geojson": "^7946.0.16",
    "@types/itemsjs": "^2.1.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "knip": "^6.9.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
